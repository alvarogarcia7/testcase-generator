{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Requirement Coverage Report",
  "description": "Schema for requirement coverage analysis report generated by req-coverage tool",
  "type": "object",
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp when the coverage report was generated (ISO 8601 format)"
    },
    "summary": {
      "type": "object",
      "description": "Summary statistics of requirement coverage",
      "properties": {
        "total_requirements": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of requirements analyzed"
        },
        "fully_covered": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of requirements with full coverage"
        },
        "partially_covered": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of requirements with partial coverage"
        },
        "uncovered": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of requirements with no coverage"
        }
      },
      "required": [
        "total_requirements",
        "fully_covered",
        "partially_covered",
        "uncovered"
      ]
    },
    "requirements": {
      "type": "array",
      "description": "List of requirement coverage items",
      "items": {
        "$ref": "#/definitions/RequirementCoverageItem"
      }
    }
  },
  "required": [
    "generated_at",
    "summary",
    "requirements"
  ],
  "definitions": {
    "RequirementCoverageItem": {
      "type": "object",
      "description": "Coverage information for a single requirement",
      "properties": {
        "requirement_id": {
          "type": "string",
          "description": "Unique identifier for the requirement"
        },
        "coverage_type": {
          "$ref": "#/definitions/CoverageType"
        },
        "test_cases": {
          "type": "array",
          "description": "List of test cases covering this requirement",
          "items": {
            "$ref": "#/definitions/TestCaseResult"
          }
        },
        "status": {
          "$ref": "#/definitions/CoverageStatus"
        }
      },
      "required": [
        "requirement_id",
        "coverage_type",
        "test_cases",
        "status"
      ]
    },
    "CoverageType": {
      "type": "string",
      "description": "Type of coverage for the requirement",
      "enum": [
        "full",
        "partial"
      ]
    },
    "CoverageStatus": {
      "type": "string",
      "description": "Coverage status combining coverage type and test results",
      "enum": [
        "covered_pass",
        "covered_fail",
        "partial_covered_pass",
        "partial_covered_fail",
        "uncovered"
      ]
    },
    "TestCaseResult": {
      "type": "object",
      "description": "Test case execution result for requirement coverage",
      "properties": {
        "test_case_id": {
          "type": "string",
          "description": "Unique identifier for the test case"
        },
        "status": {
          "$ref": "#/definitions/TestStatus"
        },
        "covers": {
          "type": "string",
          "description": "Additional coverage information (optional)"
        },
        "description": {
          "type": "string",
          "description": "Description of the test case (optional)"
        }
      },
      "required": [
        "test_case_id",
        "status"
      ]
    },
    "TestStatus": {
      "type": "string",
      "description": "Execution status of a test case",
      "enum": [
        "pass",
        "fail",
        "notexecuted"
      ]
    }
  }
}
