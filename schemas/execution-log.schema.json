{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Test Execution Log Entry",
  "description": "Schema for test execution log entries",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": ["test_execution"],
      "description": "Document type (optional, for envelope support)"
    },
    "schema": {
      "type": "string",
      "pattern": "^tcms/.*\\.schema\\.v\\d+\\.json$",
      "description": "Schema reference (optional, for envelope support)"
    },
    "test_sequence": {
      "type": "integer",
      "description": "Sequence number of the test"
    },
    "step": {
      "type": "integer",
      "description": "Step number within the test sequence"
    },
    "command": {
      "type": "string",
      "description": "The command that was executed"
    },
    "exit_code": {
      "type": "integer",
      "description": "Exit code of the command execution"
    },
    "output": {
      "type": "string",
      "description": "Output from the command execution"
    },
    "timestamp": {
      "type": "string",
      "description": "Timestamp of the execution (optional)"
    },
    "hook_type": {
      "type": "string",
      "description": "Type of hook execution (optional)",
      "enum": [
        "script_start",
        "setup_test",
        "before_sequence",
        "after_sequence",
        "before_step",
        "after_step",
        "teardown_test",
        "script_end"
      ]
    },
    "result_verification_pass": {
      "type": "boolean",
      "description": "Whether result verification passed"
    },
    "output_verification_pass": {
      "type": "boolean",
      "description": "Whether output verification passed"
    }
  },
  "required": [
    "test_sequence",
    "step",
    "command",
    "exit_code",
    "output",
    "result_verification_pass",
    "output_verification_pass"
  ]
}
