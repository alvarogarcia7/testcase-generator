{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Test Verification Output Schema",
  "description": "JSON schema for validating test verification output files generated by the test executor",
  "type": "object",
  "properties": {
    "test_case_id": {
      "type": "string",
      "description": "Unique identifier for the test case"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the test case"
    },
    "sequences": {
      "type": "array",
      "description": "Array of test sequences executed",
      "items": {
        "type": "object",
        "properties": {
          "sequence_id": {
            "type": "integer",
            "description": "Unique identifier for the test sequence",
            "minimum": 1
          },
          "name": {
            "type": "string",
            "description": "Name of the test sequence"
          },
          "step_results": {
            "type": "array",
            "description": "Results for each step in the sequence",
            "items": {
              "description": "Verification result for a single step (internally tagged with status field)",
              "type": "object",
              "required": ["status", "step", "description"],
              "properties": {
                "status": {
                  "type": "string",
                  "enum": ["pass", "fail", "not_executed"],
                  "description": "Status of the step verification"
                },
                "step": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Step number"
                },
                "description": {
                  "type": "string",
                  "description": "Step description"
                },
                "requirement": {
                  "type": "string",
                  "description": "Requirement identifier (optional, for reporting)"
                },
                "item": {
                  "type": "integer",
                  "description": "Item number (optional, for reporting)"
                },
                "tc": {
                  "type": "integer",
                  "description": "TC number (optional, for reporting)"
                },
                "expected": {
                  "type": "object",
                  "description": "Expected outcome (only present when status is fail)",
                  "properties": {
                    "success": {
                      "type": ["boolean", "null"]
                    },
                    "result": {
                      "type": "string"
                    },
                    "output": {
                      "type": "string"
                    }
                  },
                  "required": ["result", "output"]
                },
                "actual_result": {
                  "type": "string",
                  "description": "Actual result from execution (only present when status is fail)"
                },
                "actual_output": {
                  "type": "string",
                  "description": "Actual output from execution (only present when status is fail)"
                },
                "reason": {
                  "type": "string",
                  "description": "Reason for failure (only present when status is fail)"
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "status": { "const": "fail" }
                    }
                  },
                  "then": {
                    "required": ["expected", "actual_result", "actual_output", "reason"]
                  }
                }
              ]
            }
          },
          "all_steps_passed": {
            "type": "boolean",
            "description": "Whether all steps in this sequence passed"
          },
          "requirement": {
            "type": "string",
            "description": "Requirement identifier (optional, for reporting)"
          },
          "item": {
            "type": "integer",
            "description": "Item number (optional, for reporting)"
          },
          "tc": {
            "type": "integer",
            "description": "TC number (optional, for reporting)"
          }
        },
        "required": ["sequence_id", "name", "step_results", "all_steps_passed"]
      }
    },
    "total_steps": {
      "type": "integer",
      "description": "Total number of steps across all sequences",
      "minimum": 0
    },
    "passed_steps": {
      "type": "integer",
      "description": "Number of steps that passed",
      "minimum": 0
    },
    "failed_steps": {
      "type": "integer",
      "description": "Number of steps that failed",
      "minimum": 0
    },
    "not_executed_steps": {
      "type": "integer",
      "description": "Number of steps that were not executed",
      "minimum": 0
    },
    "overall_pass": {
      "type": "boolean",
      "description": "Whether the entire test case passed"
    },
    "requirement": {
      "type": "string",
      "description": "Requirement identifier (optional, for reporting)"
    },
    "item": {
      "type": "integer",
      "description": "Item number (optional, for reporting)"
    },
    "tc": {
      "type": "integer",
      "description": "TC number (optional, for reporting)"
    }
  },
  "required": [
    "test_case_id",
    "description",
    "sequences",
    "total_steps",
    "passed_steps",
    "failed_steps",
    "not_executed_steps",
    "overall_pass"
  ]
}
