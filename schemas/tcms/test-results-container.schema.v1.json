{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://tcms.example.com/schemas/tcms/test-results-container.schema.v1.json",
  "title": "TCMS Test Case Results Container Schema v1",
  "description": "JSON schema for validating test case result container YAML/JSON output from the verifier",
  "allOf": [
    {
      "$ref": "../tcms-envelope.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "test_results_container"
        },
        "schema": {
          "const": "tcms/test-results-container.schema.v1.json"
        },
        "title": {
          "type": "string",
          "description": "Title of the test report",
          "minLength": 1,
          "maxLength": 200
        },
        "project": {
          "type": "string",
          "description": "Name of the project being tested",
          "minLength": 1,
          "maxLength": 200
        },
        "test_date": {
          "type": "string",
          "description": "Test execution date in ISO 8601 format",
          "format": "date-time"
        },
        "test_results": {
          "type": "array",
          "description": "Array of test case verification results",
          "items": {
            "type": "object",
            "properties": {
              "test_case_id": {
                "type": "string",
                "description": "Unique identifier for the test case"
              },
              "description": {
                "type": "string",
                "description": "Human-readable description of the test case"
              },
              "sequences": {
                "type": "array",
                "description": "Array of test sequences executed",
                "items": {
                  "type": "object",
                  "properties": {
                    "sequence_id": {
                      "type": "integer",
                      "description": "Unique identifier for the test sequence",
                      "minimum": 1
                    },
                    "name": {
                      "type": "string",
                      "description": "Name of the test sequence"
                    },
                    "step_results": {
                      "type": "array",
                      "description": "Results for each step in the sequence",
                      "items": {
                        "description": "Verification result for a single step (externally tagged enum)",
                        "type": "object",
                        "oneOf": [
                          {
                            "type": "object",
                            "description": "Step passed verification",
                            "required": ["Pass"],
                            "properties": {
                              "Pass": {
                                "type": "object",
                                "required": ["step", "description"],
                                "properties": {
                                  "step": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "description": "Step number"
                                  },
                                  "description": {
                                    "type": "string",
                                    "description": "Step description"
                                  },
                                  "requirement": {
                                    "type": "string",
                                    "description": "Requirement identifier (optional, for reporting)"
                                  },
                                  "item": {
                                    "type": "integer",
                                    "description": "Item number (optional, for reporting)"
                                  },
                                  "tc": {
                                    "type": "integer",
                                    "description": "TC number (optional, for reporting)"
                                  }
                                },
                                "additionalProperties": false
                              }
                            },
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "description": "Step failed verification",
                            "required": ["Fail"],
                            "properties": {
                              "Fail": {
                                "type": "object",
                                "required": ["step", "description", "expected", "actual_result", "actual_output", "reason"],
                                "properties": {
                                  "step": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "description": "Step number"
                                  },
                                  "description": {
                                    "type": "string",
                                    "description": "Step description"
                                  },
                                  "expected": {
                                    "type": "object",
                                    "description": "Expected outcome",
                                    "properties": {
                                      "success": {
                                        "type": ["boolean", "null"]
                                      },
                                      "result": {
                                        "type": "string"
                                      },
                                      "output": {
                                        "type": "string"
                                      }
                                    },
                                    "required": ["result", "output"]
                                  },
                                  "actual_result": {
                                    "type": "string",
                                    "description": "Actual result from execution"
                                  },
                                  "actual_output": {
                                    "type": "string",
                                    "description": "Actual output from execution"
                                  },
                                  "reason": {
                                    "type": "string",
                                    "description": "Reason for failure"
                                  },
                                  "requirement": {
                                    "type": "string",
                                    "description": "Requirement identifier (optional, for reporting)"
                                  },
                                  "item": {
                                    "type": "integer",
                                    "description": "Item number (optional, for reporting)"
                                  },
                                  "tc": {
                                    "type": "integer",
                                    "description": "TC number (optional, for reporting)"
                                  }
                                },
                                "additionalProperties": false
                              }
                            },
                            "additionalProperties": false
                          },
                          {
                            "type": "object",
                            "description": "Step was not found in execution log",
                            "required": ["NotExecuted"],
                            "properties": {
                              "NotExecuted": {
                                "type": "object",
                                "required": ["step", "description"],
                                "properties": {
                                  "step": {
                                    "type": "integer",
                                    "minimum": 1,
                                    "description": "Step number"
                                  },
                                  "description": {
                                    "type": "string",
                                    "description": "Step description"
                                  },
                                  "requirement": {
                                    "type": "string",
                                    "description": "Requirement identifier (optional, for reporting)"
                                  },
                                  "item": {
                                    "type": "integer",
                                    "description": "Item number (optional, for reporting)"
                                  },
                                  "tc": {
                                    "type": "integer",
                                    "description": "TC number (optional, for reporting)"
                                  }
                                },
                                "additionalProperties": false
                              }
                            },
                            "additionalProperties": false
                          }
                        ]
                      }
                    },
                    "all_steps_passed": {
                      "type": "boolean",
                      "description": "Whether all steps in this sequence passed"
                    },
                    "requirement": {
                      "type": "string",
                      "description": "Requirement identifier (optional, for reporting)"
                    },
                    "item": {
                      "type": "integer",
                      "description": "Item number (optional, for reporting)"
                    },
                    "tc": {
                      "type": "integer",
                      "description": "TC number (optional, for reporting)"
                    }
                  },
                  "required": ["sequence_id", "name", "step_results", "all_steps_passed"]
                }
              },
              "total_steps": {
                "type": "integer",
                "description": "Total number of steps across all sequences",
                "minimum": 0
              },
              "passed_steps": {
                "type": "integer",
                "description": "Number of steps that passed",
                "minimum": 0
              },
              "failed_steps": {
                "type": "integer",
                "description": "Number of steps that failed",
                "minimum": 0
              },
              "not_executed_steps": {
                "type": "integer",
                "description": "Number of steps that were not executed",
                "minimum": 0
              },
              "overall_pass": {
                "type": "boolean",
                "description": "Whether the entire test case passed"
              },
              "requirement": {
                "type": "string",
                "description": "Requirement identifier (optional, for reporting)"
              },
              "item": {
                "type": "integer",
                "description": "Item number (optional, for reporting)"
              },
              "tc": {
                "type": "integer",
                "description": "TC number (optional, for reporting)"
              }
            },
            "required": [
              "test_case_id",
              "description",
              "sequences",
              "total_steps",
              "passed_steps",
              "failed_steps",
              "not_executed_steps",
              "overall_pass"
            ]
          }
        },
        "metadata": {
          "type": "object",
          "description": "Container report metadata",
          "properties": {
            "environment": {
              "type": "string",
              "description": "Environment in which the tests were executed (optional)",
              "minLength": 1,
              "maxLength": 100
            },
            "platform": {
              "type": "string",
              "description": "Platform information including OS and architecture (optional)",
              "minLength": 1,
              "maxLength": 150
            },
            "executor": {
              "type": "string",
              "description": "Information about the executor or CI/CD system running the tests (optional)",
              "minLength": 1,
              "maxLength": 150
            },
            "execution_duration": {
              "type": "number",
              "description": "Execution duration in seconds",
              "minimum": 0
            },
            "total_test_cases": {
              "type": "integer",
              "description": "Total number of test cases",
              "minimum": 0
            },
            "passed_test_cases": {
              "type": "integer",
              "description": "Number of test cases that passed",
              "minimum": 0
            },
            "failed_test_cases": {
              "type": "integer",
              "description": "Number of test cases that failed",
              "minimum": 0
            }
          },
          "required": [
            "execution_duration",
            "total_test_cases",
            "passed_test_cases",
            "failed_test_cases"
          ]
        }
      },
      "required": [
        "type",
        "schema",
        "title",
        "project",
        "test_date",
        "test_results",
        "metadata"
      ],
      "additionalProperties": false
    }
  ]
}
